{
  "name": "itp-foto-server",
  "version": "1.2.7",
  "description": "Server local InspectorCam - fotografiere vehicule la ITP",
  "main": "src/electron/main.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "electron": "npm run rebuild-electron && ELECTRON_RUN_AS_NODE= electron .",
    "rebuild-node": "npm rebuild better-sqlite3",
    "rebuild-electron": "ELECTRON_RUN_AS_NODE= electron-rebuild -f -w better-sqlite3",
    "sync-version": "node scripts/sync-version.js",
    "prebuild": "node scripts/write-pwa-source-path.js && node scripts/sync-version.js",
    "build": "electron-builder",
    "sync-pwa": "node scripts/sync-pwa.js",
    "watch-pwa": "node scripts/sync-pwa.js --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "bonjour-service": "^1.2.1",
    "chokidar": "^3.6.0",
    "electron-updater": "^6.8.3",
    "express": "^4.18.3",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "nodemon": "^3.1.0"
  }
}
